<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ReplayGuard · {{ result.title }}</title>
  <style>
    :root {
      --ink: #17201c;
      --muted: #66716b;
      --paper: #f5f7f3;
      --panel: #ffffff;
      --line: #dce3dd;
      --green: #196b45;
      --green-soft: #e7f5ed;
      --red: #a53a32;
      --red-soft: #faece9;
      --amber: #956417;
      --amber-soft: #fff4d8;
      --blue: #315c9b;
      --blue-soft: #eaf1fb;
      --shadow: 0 16px 48px rgba(23, 32, 28, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      background:
        radial-gradient(circle at 85% -10%, rgba(75, 146, 104, .15), transparent 35rem),
        var(--paper);
      color: var(--ink);
      font: 15px/1.55 Inter, ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    main { max-width: 1180px; margin: 0 auto; padding: 52px 28px 80px; }
    .eyebrow {
      color: var(--green);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .15em;
      text-transform: uppercase;
    }
    h1 { margin: 8px 0 10px; font-size: clamp(34px, 5vw, 62px); line-height: 1; letter-spacing: -.045em; }
    h2 { margin: 0; font-size: 23px; letter-spacing: -.02em; }
    h3 { margin: 0; font-size: 17px; }
    p { margin: 0; }
    code { font-family: "SFMono-Regular", Consolas, monospace; font-size: .9em; }
    .hero { display: grid; grid-template-columns: 1fr auto; gap: 28px; align-items: end; }
    .dek { max-width: 760px; color: var(--muted); font-size: 18px; }
    .outcome {
      min-width: 230px;
      padding: 18px 20px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--panel);
      box-shadow: var(--shadow);
    }
    .outcome.pass { border-color: #a4d1b6; background: var(--green-soft); }
    .outcome.fail { border-color: #e2aaa4; background: var(--red-soft); }
    .outcome strong { display: block; font-size: 21px; }
    .outcome span { color: var(--muted); font-size: 13px; }
    .question {
      margin-top: 34px;
      padding: 22px 24px;
      border-left: 4px solid var(--green);
      border-radius: 0 14px 14px 0;
      background: rgba(255,255,255,.7);
    }
    .question .label { color: var(--muted); font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; }
    .question .text { margin-top: 5px; font-size: 17px; font-weight: 650; }
    .metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 28px 0; }
    .metric { padding: 18px; border: 1px solid var(--line); border-radius: 14px; background: var(--panel); }
    .metric strong { display: block; font-size: 28px; line-height: 1.1; }
    .metric span { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: .08em; }
    .metric.good strong { color: var(--green); }
    .metric.bad strong { color: var(--red); }
    .metric.warn strong { color: var(--amber); }
    section { margin-top: 38px; }
    .section-head { display: flex; justify-content: space-between; align-items: baseline; gap: 20px; margin-bottom: 14px; }
    .section-head p { color: var(--muted); }
    .table-wrap { overflow: auto; border: 1px solid var(--line); border-radius: 16px; background: var(--panel); box-shadow: var(--shadow); }
    table { width: 100%; min-width: 880px; border-collapse: collapse; }
    th { padding: 13px 16px; color: var(--muted); font-size: 11px; letter-spacing: .09em; text-align: left; text-transform: uppercase; background: #f9faf8; }
    td { padding: 16px; border-top: 1px solid var(--line); vertical-align: top; }
    td:first-child { font-weight: 750; }
    .badge { display: inline-flex; align-items: center; padding: 4px 9px; border-radius: 999px; font-size: 11px; font-weight: 800; letter-spacing: .05em; text-transform: uppercase; white-space: nowrap; }
    .badge.pass, .badge.stable, .badge.appropriately_changed { color: var(--green); background: var(--green-soft); }
    .badge.fail, .badge.brittle, .badge.execution_error { color: var(--red); background: var(--red-soft); }
    .badge.invalid, .badge.invalid_test { color: var(--amber); background: var(--amber-soft); }
    .badge.baseline { color: var(--blue); background: var(--blue-soft); }
    .badge.model { color: var(--blue); background: var(--blue-soft); }
    .badge.deterministic { color: #4b5750; background: #eef1ee; }
    .rows { display: grid; gap: 12px; }
    details {
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 15px;
      background: var(--panel);
    }
    details[open] { box-shadow: var(--shadow); }
    summary { display: grid; grid-template-columns: minmax(190px, 1fr) 2fr auto; gap: 18px; align-items: center; padding: 18px 20px; cursor: pointer; list-style: none; }
    summary::-webkit-details-marker { display: none; }
    summary:hover { background: #fafbf9; }
    .summary-title { font-weight: 780; }
    .summary-copy { color: var(--muted); }
    .details-body { padding: 0 20px 22px; border-top: 1px solid var(--line); }
    .callout { margin: 18px 0; padding: 14px 16px; border-radius: 11px; background: #f6f8f5; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .card { min-width: 0; padding: 16px; border: 1px solid var(--line); border-radius: 12px; background: #fbfcfa; }
    .card .label { color: var(--muted); font-size: 11px; font-weight: 750; letter-spacing: .08em; text-transform: uppercase; }
    .answer { margin-top: 8px; white-space: pre-wrap; }
    .list { margin: 8px 0 0; padding-left: 18px; }
    .evidence-change { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 8px; }
    .chip { padding: 4px 8px; border-radius: 7px; background: #edf1ed; font: 12px "SFMono-Regular", Consolas, monospace; }
    .chip.add { color: var(--green); background: var(--green-soft); }
    .chip.remove { color: var(--red); background: var(--red-soft); }
    .checklist { margin-top: 16px; display: grid; gap: 8px; }
    .check { display: grid; grid-template-columns: 20px 1fr auto; gap: 9px; align-items: start; padding: 10px 12px; border-radius: 10px; background: #f8faf7; }
    .check .mark { color: var(--green); font-weight: 900; }
    .check.failed .mark { color: var(--red); }
    .check small { color: var(--muted); display: block; }
    .comparisons { margin-top: 14px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
    .comparison { padding: 11px; border: 1px solid var(--line); border-radius: 9px; }
    .comparison strong { display: block; margin-bottom: 3px; font-size: 11px; text-transform: uppercase; letter-spacing: .07em; }
    .comparison span { color: var(--muted); font-size: 13px; }
    .meta { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
    .meta div { padding: 13px; border: 1px solid var(--line); border-radius: 10px; background: var(--panel); }
    .meta dt { color: var(--muted); font-size: 10px; text-transform: uppercase; letter-spacing: .08em; }
    .meta dd { margin: 4px 0 0; overflow-wrap: anywhere; font-family: "SFMono-Regular", Consolas, monospace; font-size: 12px; }
    .warning { margin-top: 12px; padding: 12px 14px; color: #6c4a14; border: 1px solid #efd38b; border-radius: 10px; background: var(--amber-soft); }
    footer { margin-top: 48px; padding-top: 18px; border-top: 1px solid var(--line); color: var(--muted); font-size: 12px; }
    @media (max-width: 820px) {
      main { padding: 34px 18px 60px; }
      .hero { grid-template-columns: 1fr; }
      .outcome { min-width: 0; }
      .metrics, .grid-2, .comparisons, .meta { grid-template-columns: 1fr 1fr; }
      summary { grid-template-columns: 1fr auto; }
      .summary-copy { grid-column: 1 / -1; grid-row: 2; }
    }
    @media (max-width: 520px) { .metrics, .grid-2, .comparisons, .meta { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
{% set baseline = result.evaluations[0] %}
<main>
  <header>
    <div class="hero">
      <div>
        <div class="eyebrow">ReplayGuard · metamorphic evidence test</div>
        <h1>{{ result.title }}</h1>
        <p class="dek">Tests whether an evidence-grounded AI system stays stable when evidential meaning is preserved and responds when support disappears.</p>
      </div>
      <div class="outcome {{ 'pass' if result.summary.overall_pass else 'fail' }}">
        <strong>{{ 'All contracts held' if result.summary.overall_pass else 'Brittleness detected' }}</strong>
        <span>CI exit status {{ 0 if result.summary.overall_pass else (2 if result.summary.errors or result.summary.invalid else 1) }}</span>
      </div>
    </div>
    <div class="question">
      <div class="label">Claim under test</div>
      <div class="text">{{ result.claim }}</div>
    </div>
  </header>

  <div class="metrics">
    <div class="metric good"><strong>{{ result.summary.passed }}</strong><span>Contracts passed</span></div>
    <div class="metric bad"><strong>{{ result.summary.brittle }}</strong><span>Brittle transitions</span></div>
    <div class="metric warn"><strong>{{ result.summary.invalid }}</strong><span>Invalid tests</span></div>
    <div class="metric bad"><strong>{{ result.summary.errors }}</strong><span>Execution errors</span></div>
  </div>

  <section>
    <div class="section-head">
      <h2>Transition matrix</h2>
      <p>The primary result is behavior, not an abstract score.</p>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Replay</th><th>Evidence state</th><th>Expected</th><th>Observed</th><th>Result</th></tr></thead>
        <tbody>
        {% for row in result.evaluations %}
          <tr>
            <td>{{ row.label }}</td>
            <td>{{ row.evidence_state }}</td>
            <td>{{ row.expected_transition }}</td>
            <td>{{ row.observed_transition }}</td>
            <td><span class="badge {{ row.verdict }}">{{ row.verdict | replace('_', ' ') }}</span></td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Replay evidence</h2>
      <p>Open a row to see the exact transition and rule trace.</p>
    </div>
    <div class="rows">
    {% for row in result.evaluations[1:] %}
      <details {% if row.row_result != 'pass' %}open{% endif %}>
        <summary>
          <div class="summary-title">{{ row.label }}</div>
          <div class="summary-copy">{{ row.explanation }}</div>
          <span class="badge {{ row.row_result }}">{{ row.row_result }}</span>
        </summary>
        <div class="details-body">
          <div class="callout"><strong>Rule:</strong> {{ row.expected_transition }}. <strong>Observed:</strong> {{ row.observed_transition }}.</div>
          <div class="grid-2">
            <div class="card">
              <div class="label">Baseline answer</div>
              <div class="answer">{{ baseline.target_response.answer if baseline.target_response else 'Unavailable' }}</div>
              {% if baseline.target_response %}
              <ul class="list"><li>Verdict: <code>{{ baseline.target_response.verdict }}</code></li><li>Citations: {{ baseline.target_response.citations | join(', ') or 'none' }}</li></ul>
              {% endif %}
            </div>
            <div class="card">
              <div class="label">Replay answer</div>
              <div class="answer">{{ row.target_response.answer if row.target_response else 'Unavailable' }}</div>
              {% if row.target_response %}
              <ul class="list"><li>Verdict: <code>{{ row.target_response.verdict }}</code></li><li>Citations: {{ row.target_response.citations | join(', ') or 'none' }}</li></ul>
              {% endif %}
            </div>
          </div>

          <div class="grid-2" style="margin-top:14px">
            <div class="card">
              <div class="label">Evidence change</div>
              <div class="evidence-change">
                {% for item in row.added_evidence_ids %}<span class="chip add">+ {{ item }}</span>{% endfor %}
                {% for item in row.removed_evidence_ids %}<span class="chip remove">− {{ item }}</span>{% endfor %}
                {% if not row.added_evidence_ids and not row.removed_evidence_ids %}<span class="chip">no document-ID change</span>{% endif %}
              </div>
            </div>
            <div class="card">
              <div class="label">Replay packet</div>
              <div class="evidence-change">
                {% for document in row.evidence %}<span class="chip">{{ document.id }} · {{ document.role }}</span>{% else %}<span class="chip">empty</span>{% endfor %}
              </div>
            </div>
          </div>

          <div class="comparisons">
            <div class="comparison"><strong>Answer</strong><span>{{ row.comparison.answer }}</span></div>
            <div class="comparison"><strong>Claims</strong><span>{{ row.comparison.claims }}</span></div>
            <div class="comparison"><strong>Citations</strong><span>{{ row.comparison.citations }}</span></div>
            <div class="comparison"><strong>Support</strong><span>{{ row.comparison.surviving_support }}</span></div>
          </div>

          <div class="checklist">
          {% for check in row.checks %}
            <div class="check {{ '' if check.passed else 'failed' }}">
              <div class="mark">{{ '✓' if check.passed else '×' }}</div>
              <div><strong>{{ check.name }}</strong><small>{{ check.detail }}</small></div>
              <span class="badge {{ 'model' if check.source == 'model_assisted' else 'deterministic' }}">{{ check.source | replace('_', ' ') }}{% if not check.gating %} · advisory{% endif %}</span>
            </div>
          {% endfor %}
          </div>
        </div>
      </details>
    {% endfor %}
    </div>
  </section>

  <section>
    <div class="section-head"><h2>Reproducibility ledger</h2><p>Enough metadata to replay the run without exposing secrets.</p></div>
    <dl class="meta">
      <div><dt>Run ID</dt><dd>{{ result.metadata.run_id }}</dd></div>
      <div><dt>Created</dt><dd>{{ result.metadata.created_at }}</dd></div>
      <div><dt>Fixture SHA-256</dt><dd>{{ result.metadata.fixture_sha256 }}</dd></div>
      <div><dt>Target adapter</dt><dd>{{ result.metadata.target_adapter }}</dd></div>
      <div><dt>Analysis mode</dt><dd>{{ result.metadata.analysis_mode_effective }}</dd></div>
      <div><dt>GPT model</dt><dd>{{ result.metadata.model.model_returned or result.metadata.model.model_requested or 'not requested' }}</dd></div>
      <div><dt>Reasoning effort</dt><dd>{{ result.metadata.model.reasoning_effort or 'not requested' }}</dd></div>
      <div><dt>Prompt version</dt><dd>{{ result.metadata.model.prompt_version or 'not requested' }}</dd></div>
      <div><dt>Prompt SHA-256</dt><dd>{{ result.metadata.model.prompt_sha256 or 'not requested' }}</dd></div>
    </dl>
    {% if result.metadata.model.warning %}<div class="warning"><strong>Model note:</strong> {{ result.metadata.model.warning }}</div>{% endif %}
  </section>

  <footer>
    ReplayGuard v{{ result.metadata.replayguard_version }} · Deterministic transition rules own the final verdict. GPT-5.6 semantic signals are identified row by row.
  </footer>
</main>
</body>
</html>
