# Required for --analysis-mode model. Never commit the real key.
OPENAI_API_KEY=

# Default semantic-analysis model and reasoning effort.
REPLAYGUARD_MODEL=gpt-5.6
REPLAYGUARD_REASONING_EFFORT=low

# Structured logs are quiet by default; --verbose enables info-level events.
REPLAYGUARD_LOG_LEVEL=WARNING
REPLAYGUARD_LOG_FORMAT=json

# HTTP target-adapter defaults.
REPLAYGUARD_HTTP_TIMEOUT_SECONDS=30

# Optional bearer token used only when a fixture sets api_key_env to this name.
REPLAYGUARD_TARGET_API_KEY=
